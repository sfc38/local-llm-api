[Unit]
Description=Local LLM Streamlit UI
After=network.target local-llm-api.service

[Service]
User=ubuntu
WorkingDirectory=/home/ubuntu/local-llm-api
ExecStart=/home/ubuntu/local-llm-api/venv/bin/streamlit run streamlit_app.py \
    --server.address 0.0.0.0 \
    --server.port 8501 \
    --server.headless true
Restart=always
RestartSec=5
Environment=HOME=/home/ubuntu
Environment=API_URL=http://localhost:8000

[Install]
WantedBy=multi-user.target
